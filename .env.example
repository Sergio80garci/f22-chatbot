# Groq API (LLM - gratuito en console.groq.com)
GROQ_API_KEY=tu-groq-api-key-aqui
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (embeddings locales - requiere Ollama corriendo)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PATH=./data/chroma_db
DOCS_PATH=./data/f22/raw
PROCESSED_PATH=./data/f22/processed

# CORS: separar con comas si hay múltiples orígenes
ALLOWED_ORIGINS=http://localhost:5173
